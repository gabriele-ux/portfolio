---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Gabriele La Rosa — Portfolio">
  <section class="flex flex-col items-center justify-center min-h-[60vh] px-6 gap-6 text-center">
    <h1 class="font-[var(--font-display)] font-bold text-[40px] text-white">
      Portfolio in costruzione
    </h1>
    <p class="text-[16px] text-[var(--color-text-body)] max-w-prose">
      Per ora è disponibile solo la pagina di dettaglio del case study come template.
    </p>
    <a
      href="/case-study/sample"
      class="text-[var(--color-accent-1)] underline-offset-4 hover:underline"
    >
      Apri il sample case study →
    </a>
  </section>
</BaseLayout>
