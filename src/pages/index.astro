---
import BaseLayout from "../layouts/BaseLayout.astro";
import Container from "../components/case-study/Container.astro";
import HomeHero from "../components/home/HomeHero.astro";
import ProjectCard from "../components/home/ProjectCard.astro";
import HomeFooter from "../components/home/HomeFooter.astro";

const projects = [
  {
    href: "/case-study/sample",
    title: "Title",
    tags: ["PROJECT", "UX", "2026"],
  },
  {
    href: "/case-study/sample",
    title: "Title",
    tags: ["PROJECT", "UX", "2026"],
  },
];
---

<BaseLayout title="Gabriele La Rosa — Portfolio" hideFooter>
  <article class="relative">
    <div class="relative z-10">
      <HomeHero />

      <Container
        pyClass="pt-0 pb-[clamp(80px,12.5vw,180px)]"
        bgClass="bg-[var(--color-bg)] rounded-b-[32px] relative z-[1]"
      >
        <div class="flex flex-col gap-[24px] w-full">
          <!-- Tag "SELECTED PROJECTS" + arrow-down (senza divider full-width) -->
          <div class="home-selected__tag">
            <span class="home-selected__label">SELECTED PROJECTS</span>
            <svg
              width="16"
              height="16"
              viewBox="0 0 16 16"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path d="M12.854 9.35375L8.35403 13.8538C8.30759 13.9002 8.25245 13.9371 8.19175 13.9623C8.13105 13.9874 8.06599 14.0004 8.00028 14.0004C7.93457 14.0004 7.86951 13.9874 7.80881 13.9623C7.74811 13.9371 7.69296 13.9002 7.64653 13.8538L3.14653 9.35375C3.05271 9.25993 3 9.13268 3 9C3 8.86732 3.05271 8.74007 3.14653 8.64625C3.24035 8.55243 3.3676 8.49972 3.50028 8.49972C3.63296 8.49972 3.76021 8.55243 3.85403 8.64625L7.50028 12.2931V2.5C7.50028 2.36739 7.55296 2.24021 7.64672 2.14645C7.74049 2.05268 7.86767 2 8.00028 2C8.13289 2 8.26006 2.05268 8.35383 2.14645C8.4476 2.24021 8.50028 2.36739 8.50028 2.5V12.2931L12.1465 8.64625C12.2403 8.55243 12.3676 8.49972 12.5003 8.49972C12.633 8.49972 12.7602 8.55243 12.854 8.64625C12.9478 8.74007 13.0006 8.86732 13.0006 9C13.0006 9.13268 12.9478 9.25993 12.854 9.35375Z" fill="white"/>
            </svg>
          </div>

          <div class="projects-grid">
            {projects.map((p) => <ProjectCard {...p} />)}
          </div>
        </div>
      </Container>
    </div>
  </article>

  <HomeFooter />
</BaseLayout>

<style>
  /* === Tag Selected Projects === */
  .home-selected__tag {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 0;
    border-radius: 8px;
    opacity: 0.9;
    color: #ffffff;
    align-self: flex-start;
  }

  .home-selected__label {
    font-family: var(--font-mono);
    font-weight: 300;
    font-size: 14px;
    line-height: 14px;
    letter-spacing: 0.32px;
    color: #ffffff;
    white-space: nowrap;
  }

  /* === Projects grid === */
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3xl);
    width: 100%;
  }

  @media (min-width: 768px) {
    .projects-grid {
      grid-template-columns: 1fr 1fr;
      gap: 32px;
    }
  }
</style>
