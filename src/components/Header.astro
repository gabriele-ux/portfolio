---
// Header globale — layout Figma 18:136.
// Left: icona + "Gabriele La Rosa" (gap 12px)
// Right: About · Work · "Let's talk" (pill button, gap 16px tra link, gap interno 8px)
// Mantiene sticky + glass dei due layer slate-blue + nero.
---

<header
  class="topbar sticky top-0 z-50 w-full h-[56px] flex items-center justify-between px-6 py-[10px]"
>
  <a
    href="/"
    class="flex items-center gap-3 text-white no-underline hover:text-[var(--color-accent-1)] transition-colors"
    aria-label="Home"
  >
    <span aria-hidden="true" class="size-6 inline-flex">
      <svg
        width="24"
        height="24"
        viewBox="0 0 24 24"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
      >
        <path
          d="M17 10H16C15.2089 10 14.4355 9.7654 13.7777 9.32588C13.1199 8.88635 12.6072 8.26164 12.3045 7.53073C12.0017 6.79983 11.9225 5.99556 12.0769 5.21964C12.2312 4.44372 12.6122 3.73098 13.1716 3.17157C13.731 2.61216 14.4437 2.2312 15.2196 2.07686C15.9956 1.92252 16.7998 2.00173 17.5307 2.30448C18.2616 2.60723 18.8864 3.11992 19.3259 3.77772C19.7654 4.43552 20 5.20888 20 6V6.534"
          stroke="url(#tb-grad-1)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path
          d="M17 6H18C18.9359 5.99967 19.8423 6.32752 20.5615 6.9265C21.2806 7.52548 21.7669 8.35765 21.9358 9.27819C22.1047 10.1987 21.9454 11.1493 21.4858 11.9646C21.0261 12.7798 20.2951 13.4081 19.42 13.74L17.13 14.61C15.7397 15.1392 14.2023 15.1329 12.8162 14.5925C11.4302 14.052 10.2943 13.0159 9.62909 11.6853C8.96388 10.3546 8.81674 8.82424 9.21623 7.39119C9.61573 5.95815 10.5334 4.72462 11.791 3.93L13.86 2.62"
          stroke="url(#tb-grad-2)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path
          d="M10 17.8C8.9 17 7.3 16.5 4.5 17C5.2 19.3 6.3 20.6 7.5 21.2C8.8 21.9 10.3 21.9 12.3 21.5C11.8 20 11.1 18.6 10 17.8Z"
          stroke="url(#tb-grad-3)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path d="M9.77 12C4 15 2 22 2 22" stroke="url(#tb-grad-4)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <path
          d="M17 10C18.1046 10 19 9.10457 19 8C19 6.89543 18.1046 6 17 6C15.8954 6 15 6.89543 15 8C15 9.10457 15.8954 10 17 10Z"
          stroke="url(#tb-grad-5)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
        <defs>
          <linearGradient id="tb-grad-1" x1="16" y1="2" x2="16" y2="10" gradientUnits="userSpaceOnUse"><stop stop-color="#FC642D"></stop><stop offset="1" stop-color="#9BE2EC"></stop></linearGradient>
          <linearGradient id="tb-grad-2" x1="15.4987" y1="2.62" x2="15.4987" y2="15.0024" gradientUnits="userSpaceOnUse"><stop stop-color="#FC642D"></stop><stop offset="1" stop-color="#9BE2EC"></stop></linearGradient>
          <linearGradient id="tb-grad-3" x1="8.4" y1="16.7998" x2="8.4" y2="21.7703" gradientUnits="userSpaceOnUse"><stop stop-color="#FC642D"></stop><stop offset="1" stop-color="#9BE2EC"></stop></linearGradient>
          <linearGradient id="tb-grad-4" x1="5.885" y1="12" x2="5.885" y2="22" gradientUnits="userSpaceOnUse"><stop stop-color="#FC642D"></stop><stop offset="1" stop-color="#9BE2EC"></stop></linearGradient>
          <linearGradient id="tb-grad-5" x1="17" y1="6" x2="17" y2="10" gradientUnits="userSpaceOnUse"><stop stop-color="#FC642D"></stop><stop offset="1" stop-color="#9BE2EC"></stop></linearGradient>
        </defs>
      </svg>
    </span>
    <span class="text-base whitespace-nowrap max-[600px]:hidden">Gabriele La Rosa</span>
  </a>

  <nav class="flex items-center gap-4" aria-label="Primary">
    <a
      href="/about"
      class="px-3 py-2 text-base text-white no-underline hover:text-[var(--color-accent-1)] transition-colors"
    >
      About
    </a>
    <a
      href="#work"
      class="px-3 py-2 text-base text-white no-underline hover:text-[var(--color-accent-1)] transition-colors"
    >
      Work
    </a>
    <a
      href="mailto:gabriele.larosa@weareconflux.com"
      class="px-3 py-2 text-base text-white no-underline rounded-[25px] bg-white/20 border border-white/30 hover:bg-white/30 transition-colors"
    >
      Let's talk
    </a>
  </nav>
</header>

<style>
  /*
   * Layered glass background: slate-blue base + black overlay (Figma 6:4 → 6:5).
   * Backdrop blur per leggibilità sopra il gradient ambient della pagina.
   */
  .topbar {
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.1), rgba(0, 0, 0, 0.1)),
      linear-gradient(rgba(129, 139, 166, 0.19), rgba(129, 139, 166, 0.19));
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
    border-bottom: 1px solid var(--color-border);
  }
</style>
