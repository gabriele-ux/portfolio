---
// Project tag chip — outline ghost.
// Bordo bianco tenue, niente background, testo 14px.
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<span
  class="tag-outline inline-flex items-center justify-center px-3 py-1 rounded-[var(--radius-tag)] text-[14px] tracking-[0.32px] text-white whitespace-nowrap"
>
  {label}
</span>

<style>
  .tag-outline {
    background-color: transparent;
    border: 1px solid rgba(255, 255, 255, 0.25);
  }
</style>
