---
/*
 * Hero del case study.
 * Layout: tag row (DM Mono con micro-dot) → h1
 * Nessuna pill outline — usa lo stesso pattern delle project card.
 */
import Container from "./Container.astro";

interface Props {
  title: string;
  tags: string[];
}
const { title, tags } = Astro.props;
---

<Container pyClass="pt-[var(--space-3xl)] pb-[var(--space-xl)]">
  <div class="flex flex-col gap-[var(--space-lg)] items-start">
    {
      tags.length > 0 && (
        <ul class="case-hero__tags" role="list">
          {tags.map((t, i) => (
            <>
              {i > 0 && <li class="case-hero__tag-sep" aria-hidden="true" />}
              <li class="case-hero__tag">{t}</li>
            </>
          ))}
        </ul>
      )
    }
    <h1 class="font-hero font-normal text-hero leading-tight text-white">
      {title}
    </h1>
  </div>
</Container>

<style>
  .case-hero__tags {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
    flex-wrap: wrap;
  }

  .case-hero__tag {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.32px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.8);
    white-space: nowrap;
  }

  .case-hero__tag-sep {
    width: 2px;
    height: 2px;
    border-radius: 100%;
    background-color: rgba(255, 255, 255, 0.6);
    flex-shrink: 0;
  }
</style>
