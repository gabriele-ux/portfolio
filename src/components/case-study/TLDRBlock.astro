---
import Container from "./Container.astro";

interface Item {
  label: string;
  body: string;
  icon: "problem" | "solution" | "impact";
}

interface Props {
  problem: string;
  solution: string;
  impact: string;
}
const { problem, solution, impact } = Astro.props;

const items: Item[] = [
  { label: "Problem", body: problem, icon: "problem" },
  { label: "Solution", body: solution, icon: "solution" },
  { label: "Impact", body: impact, icon: "impact" },
];
---

<Container pyClass="pt-[var(--space-lg)] pb-[var(--space-xl)]">
  <div
    class="glass-card tldr-card w-full rounded-[var(--radius-card)] p-6 flex flex-col gap-8 lg:flex-row lg:gap-10 lg:items-stretch lg:h-[266px]"
  >
    {
      items.map((item, i) => (
        <>
          {i > 0 && (
            <span
              aria-hidden="true"
              class="hidden lg:block w-px self-center h-[177px] bg-[var(--color-border)]"
            />
          )}
          <div class="flex-1 flex flex-col items-start text-left lg:items-center lg:text-center justify-center gap-[25px]">
            <div class="flex items-center gap-2">
              <svg
                class="size-[18px] text-white/80"
                viewBox="0 0 256 256"
                fill="currentColor"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
              >
                {item.icon === "problem" && (
                  <path d="M235.33,116.72,139.28,20.66a16,16,0,0,0-22.56,0l-96,96.06a16,16,0,0,0,0,22.56l96.05,96.06h0a16,16,0,0,0,22.56,0l96.05-96.06a16,16,0,0,0,0-22.56ZM120,80a8,8,0,0,1,16,0v56a8,8,0,0,1-16,0Zm8,104a12,12,0,1,1,12-12A12,12,0,0,1,128,184Z" />
                )}
                {item.icon === "solution" && (
                  <path d="M208,144a15.78,15.78,0,0,1-10.42,14.94L146,178l-19,51.62a15.92,15.92,0,0,1-29.88,0L78,178l-51.62-19a15.92,15.92,0,0,1,0-29.88L78,110l19-51.62a15.92,15.92,0,0,1,29.88,0L146,110l51.62,19A15.78,15.78,0,0,1,208,144ZM152,48h16V64a8,8,0,0,0,16,0V48h16a8,8,0,0,0,0-16H184V16a8,8,0,0,0-16,0V32H152a8,8,0,0,0,0,16Zm88,32h-8V72a8,8,0,0,0-16,0v8h-8a8,8,0,0,0,0,16h8v8a8,8,0,0,0,16,0V96h8a8,8,0,0,0,0-16Z" />
                )}
                {item.icon === "impact" && (
                  <path d="M232,208a8,8,0,0,1-8,8H32a8,8,0,0,1,0-16h8V136a8,8,0,0,1,8-8H72a8,8,0,0,1,8,8v64H96V88a8,8,0,0,1,8-8h32a8,8,0,0,1,8,8V200h16V40a8,8,0,0,1,8-8h40a8,8,0,0,1,8,8V200h8A8,8,0,0,1,232,208Z" />
                )}
              </svg>
              <span class="font-semibold text-[18px] leading-[25.6px] text-white">
                {item.label}
              </span>
            </div>
            <p class="text-[16px] leading-[25.6px] text-[var(--color-text-body)]">
              {item.body}
            </p>
          </div>
        </>
      ))
    }
  </div>
</Container>

<style>
  .glass-card {
    background-color: var(--color-surface);
    -webkit-backdrop-filter: blur(20px) saturate(140%);
    backdrop-filter: blur(20px) saturate(140%);
  }

  /*
   * Tra 600 e 1018px la card è in colonna ma su uno schermo medio:
   * un padding-right maggiore evita che il testo sembri appiccicato al bordo.
   * Sotto 600 e da 1018 in su: torna al default (p-6 = 24px).
   */
  @media (min-width: 600px) and (max-width: 1018px) {
    .tldr-card {
      padding-right: 32px;
    }
  }
</style>
