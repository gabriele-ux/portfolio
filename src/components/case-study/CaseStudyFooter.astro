---
/*
 * Footer specifico per le pagine di case study.
 * - Gradiente inverso rispetto al hero (top: #323232 → bottom: #4387ca)
 * - Nav row: Previous / All projects / Next (case-study pagination)
 * - "Hello 👋" tag-divider, heading hero + email pill copy-on-click
 * - Bottom row: copyright + LinkedIN
 */

import Container from "./Container.astro";

interface Props {
  email?: string;
  linkedinUrl?: string;
  previousUrl?: string;
  nextUrl?: string;
  allProjectsUrl?: string;
  year?: number;
}

const {
  email = "gabrielelarosa013@gmail.com",
  linkedinUrl = "https://www.linkedin.com/in/gabriele-la-rosa-9892b81b5/",
  previousUrl,
  nextUrl,
  allProjectsUrl = "/",
  year = new Date().getFullYear(),
} = Astro.props;
---

<footer id="case-footer" class="case-footer relative w-full overflow-hidden">
  <div class="case-footer__gradient absolute inset-0" aria-hidden="true"></div>

  <div class="relative z-10 w-full">
    <Container pyClass="pt-[var(--space-page-bottom)] pb-[var(--space-3xl)]">
      <!-- Top: case-study pagination -->
      <nav
        class="flex flex-wrap items-center justify-between gap-3 w-full"
        aria-label="Case study navigation"
      >
        <a
          href={previousUrl ?? "#"}
          class="case-footer__pill"
          aria-disabled={previousUrl ? undefined : "true"}
          tabindex={previousUrl ? undefined : -1}
        >
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M15 19l-7-7 7-7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <span>Previous</span>
        </a>
        <a href={allProjectsUrl} class="case-footer__pill">
          <span>All projects</span>
        </a>
        <a
          href={nextUrl ?? "#"}
          class="case-footer__pill"
          aria-disabled={nextUrl ? undefined : "true"}
          tabindex={nextUrl ? undefined : -1}
        >
          <span>Next</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M9 5l7 7-7 7" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </nav>

      <!-- Mid: hello + heading + email -->
      <div class="mt-[var(--space-3xl)] flex flex-col gap-[var(--space-lg)] w-full">
        <div class="w-full flex items-center gap-3">
          <span
            class="font-display py-2 text-[14px] tracking-[0.32px] text-[var(--color-text-tag)] opacity-90 whitespace-nowrap"
          >
            Hello <span aria-hidden="true">👋</span>
          </span>
          <span aria-hidden="true" class="flex-1 h-px bg-[var(--color-border)]"></span>
        </div>

        <h2 class="case-footer__heading font-hero text-white leading-tight">
          Let's design meaningful<br />products together :)
        </h2>

        <div class="mt-2">
          <button
            type="button"
            class="case-footer__email-pill"
            data-email={email}
            aria-label={`Copia email ${email}`}
          >
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.6" />
              <path d="M5 15V6a1 1 0 0 1 1-1h9" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
            </svg>
            <span class="case-footer__email-text">{email}</span>
            <span class="case-footer__email-feedback" aria-live="polite" aria-hidden="true">Copiato!</span>
          </button>
        </div>
      </div>

      <!-- Bottom: copyright + LinkedIN -->
      <div class="mt-[var(--space-3xl)] flex flex-wrap items-center justify-between gap-3 w-full">
        <span class="text-white text-[16px]">
          © Gabriele La Rosa {year}
        </span>
        <a
          href={linkedinUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="case-footer__linkedin flex items-center gap-2 text-white text-[16px] hover:text-[var(--color-accent-1)] transition-colors"
        >
          <span>LinkedIN</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M14 5h5v5M19 5l-9 9M10 5H6a1 1 0 0 0-1 1v12a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1v-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </Container>
  </div>
</footer>

<style>
  .case-footer__gradient {
    /* Esattamente l'inverso del gradient hero di inizio pagina
     * (#4387ca → #323232 dall'alto in basso). */
    background: linear-gradient(180deg, #323232 0%, #4387ca 100%);
  }

  /* --- Pagination pills (tertiary / ghost link) --- */
  .case-footer__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 12px;
    border-radius: 25px;
    background: transparent;
    border: 0;
    color: #ffffff;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: normal;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
    white-space: nowrap;
    transition:
      color 200ms ease,
      opacity 200ms ease;
  }

  @media (min-width: 768px) {
    .case-footer__pill {
      font-size: 20px;
    }
  }

  .case-footer__pill:hover {
    color: var(--color-accent-1);
  }

  .case-footer__linkedin {
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 1px;
  }

  .case-footer__pill[aria-disabled="true"] {
    opacity: 0.4;
    pointer-events: none;
    cursor: not-allowed;
  }

  /* --- Heading --- */
  .case-footer__heading {
    /* Stessa scala fluida e stesso peso (semibold/600) del titolo hero del case study */
    font-size: var(--text-hero);
    font-weight: 600;
  }

  /* --- Email pill (copy on click) — sfondo iridescente animato. --- */
  .case-footer__email-pill {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px;
    border-radius: 25px;
    border: 1px solid #c3c5f7;
    color: #181818;
    font-family: var(--font-body);
    font-size: 16px;
    line-height: normal;
    cursor: pointer;
    appearance: none;
    max-width: 100%;
    overflow: hidden;
    isolation: isolate;
    background-color: #ffffff;
    transition: transform 120ms ease;
  }

  /* Layer cangiante: gradiente multi-pastello animato che scorre lateralmente */
  .case-footer__email-pill::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: -1;
    background: linear-gradient(
      115deg,
      #ffffff 0%,
      #e6e3f8 18%,
      #fbe5f0 36%,
      #e3f0fb 54%,
      #fdf2dc 72%,
      #e6e3f8 90%,
      #ffffff 100%
    );
    background-size: 220% 100%;
    background-position: 0% 50%;
    animation: case-footer-iridescent 7s ease-in-out infinite;
  }

  @keyframes case-footer-iridescent {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .case-footer__email-pill:hover::before {
    animation-duration: 4s;
  }

  .case-footer__email-pill:active {
    transform: scale(0.98);
  }

  @media (prefers-reduced-motion: reduce) {
    .case-footer__email-pill::before {
      animation: none;
    }
  }

  .case-footer__email-text {
    transition: opacity 180ms ease;
  }

  .case-footer__email-feedback {
    position: absolute;
    inset: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
    color: #181818;
    font-weight: 600;
  }

  .case-footer__email-pill[data-copied="true"] .case-footer__email-text {
    opacity: 0;
  }
  .case-footer__email-pill[data-copied="true"] .case-footer__email-feedback {
    opacity: 1;
  }
</style>

<script>
  document
    .querySelectorAll<HTMLButtonElement>(".case-footer__email-pill")
    .forEach((btn) => {
      btn.addEventListener("click", async () => {
        const email = btn.dataset.email;
        if (!email) return;
        try {
          await navigator.clipboard.writeText(email);
          btn.dataset.copied = "true";
          setTimeout(() => {
            delete btn.dataset.copied;
          }, 1600);
        } catch {
          window.location.href = `mailto:${email}`;
        }
      });
    });
</script>
