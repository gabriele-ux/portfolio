---
// Wrapper di sezione: padding orizzontale fluido tra 24px (mobile) e 100px
// (desktop 1440vw+), limita il contenuto a 1100px e lo centra.
// Default vertical: --space-section (80px) per ritmo leggibile.
interface Props {
  pyClass?: string;
  ariaLabel?: string;
  id?: string;
  bgClass?: string;
}
const {
  pyClass = "py-[var(--space-section)]",
  ariaLabel,
  id,
  bgClass = "",
} = Astro.props;
---

<section
  class={`case-container w-full flex flex-col items-center ${pyClass} ${bgClass}`}
  aria-label={ariaLabel}
  id={id}
>
  <div class="w-full max-w-[var(--container-case-study)]">
    <slot />
  </div>
</section>

<style>
  /* Padding-x fluido responsive con 8.6vw → 124 su desktop 1440
   * (= (1440-1192)/2, così il container interno max-width 1192 combacia
   * col gutter esterno). Min 24 su mobile, max 160 su viewport ultra-large. */
  .case-container {
    padding-inline: clamp(24px, 8.6vw, 160px);
  }
</style>
