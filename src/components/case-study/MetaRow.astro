---
interface MetaItem {
  label: string;
  value: string;
}
interface Props {
  items: MetaItem[];
}
const { items } = Astro.props;
---

<div class="w-full flex flex-col items-center px-6 md:px-12 xl:px-[160px] pb-[var(--space-xl)]">
  <div
    class="w-full max-w-[var(--container-case-study)] flex flex-col items-start justify-start gap-y-2 md:flex-row md:flex-wrap md:items-center md:justify-start md:gap-x-8 md:gap-y-3 text-[16px]"
  >
    {
      items.map((item, i) => (
        <>
          {i > 0 && (
            <span
              aria-hidden="true"
              class="hidden md:inline text-[var(--color-text-muted)]"
            >
              ✦
            </span>
          )}
          <span class="flex items-center gap-1 whitespace-nowrap">
            <span class="text-[var(--color-text-body)]">{item.label}:</span>
            <span class="font-medium text-white">{item.value}</span>
          </span>
        </>
      ))
    }
  </div>
</div>
