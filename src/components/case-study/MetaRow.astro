---
import Container from "./Container.astro";

interface MetaItem {
  label: string;
  value: string;
}
interface Props {
  items: MetaItem[];
}
const { items } = Astro.props;
---

<Container pyClass="pb-[var(--space-xl)]">
  <div
    class="w-full flex flex-col items-start justify-start gap-y-2 md:flex-row md:flex-wrap md:items-center md:justify-start md:gap-x-8 md:gap-y-3 text-[16px]"
  >
    {
      items.map((item, i) => (
        <>
          {i > 0 && (
            <span
              aria-hidden="true"
              class="hidden md:inline text-[var(--color-text-muted)]"
            >
              ✹
            </span>
          )}
          <span class="flex items-center gap-2 whitespace-nowrap">
            <span
              aria-hidden="true"
              class="md:hidden text-[var(--color-text-muted)]"
            >
              ✹
            </span>
            <span class="text-[var(--color-text-body)]">{item.label}:</span>
            <span class="font-medium text-white">{item.value}</span>
          </span>
        </>
      ))
    }
  </div>
</Container>
