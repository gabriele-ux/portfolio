---
// Pattern label di sezione: tag DM Mono compatto (senza divider line).
// Usato all'inizio di ogni sezione (dopo l'hero) per dare ritmo visivo.
interface Props {
  label: string;
}
const { label } = Astro.props;
---

<span
  class="font-mono font-light uppercase py-2 text-[14px] tracking-[0.32px] text-white whitespace-nowrap"
>
  {label}
</span>
