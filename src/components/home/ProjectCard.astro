---
/*
 * Card di un progetto selezionato in homepage.
 * - Cover image (placeholder bianco se manca src)
 * - Tags row (riusa il pattern delle tag liquid del case study)
 * - Titolo + sottotitolo
 * - L'intera card è un link verso la case study page
 */
import Tag from "../case-study/Tag.astro";

interface Props {
  href: string;
  title: string;
  subtitle?: string;
  tags?: string[];
  cover?: string;
  coverAlt?: string;
}

const {
  href,
  title,
  subtitle,
  tags = [],
  cover,
  coverAlt = "",
} = Astro.props;
---

<a href={href} class="project-card group">
  <div class="project-card__media">
    {cover ? (
      <img src={cover} alt={coverAlt} class="project-card__img" />
    ) : (
      <div class="project-card__placeholder" aria-hidden="true"></div>
    )}
  </div>

  {tags.length > 0 && (
    <div class="flex flex-wrap gap-2 mt-[var(--space-lg)]">
      {tags.map((t) => <Tag label={t} />)}
    </div>
  )}

  <h2 class="project-card__title">{title}</h2>
  {subtitle && <p class="project-card__subtitle">{subtitle}</p>}
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .project-card__media {
    width: 100%;
    aspect-ratio: 16 / 11;
    border-radius: var(--radius-card);
    overflow: hidden;
    background-color: rgba(129, 139, 166, 0.1);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card:hover .project-card__media {
    transform: translateY(-4px);
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: #ffffff;
  }

  .project-card__title {
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: 28px;
    line-height: 1.2;
    color: #ffffff;
  }

  .project-card__subtitle {
    margin-top: var(--space-2xs);
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.4;
    color: var(--color-text-body);
  }
</style>
