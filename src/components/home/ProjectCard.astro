---
/*
 * Card di un progetto selezionato in homepage — Figma 51:77.
 * - Cover image (placeholder bianco se manca src), aspect 544/390 (~1.4:1)
 * - Tag row: testo DM Mono separato da micro-dot (2px), no outline
 * - Titolo: Bricolage semibold 24px
 * - L'intera card è un link verso la case study page
 */

interface Props {
  href: string;
  title: string;
  tags?: string[];
  cover?: string;
  coverAlt?: string;
}

const { href, title, tags = [], cover, coverAlt = "" } = Astro.props;
---

<a href={href} class="project-card">
  <div class="project-card__media">
    {
      cover ? (
        <img src={cover} alt={coverAlt} class="project-card__img" />
      ) : (
        <div class="project-card__placeholder" aria-hidden="true" />
      )
    }
  </div>

  {
    tags.length > 0 && (
      <ul class="project-card__tags" role="list">
        {tags.map((t, i) => (
          <>
            {i > 0 && (
              <li class="project-card__tag-sep" aria-hidden="true" />
            )}
            <li class="project-card__tag">{t}</li>
          </>
        ))}
      </ul>
    )
  }

  <h2 class="project-card__title">{title}</h2>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
  }

  .project-card__media {
    width: 100%;
    /* 544x390 dal Figma → ratio ~1.395 */
    aspect-ratio: 544 / 390;
    border-radius: 8px;
    overflow: hidden;
    background-color: rgba(129, 139, 166, 0.1);
    transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .project-card:hover .project-card__media {
    transform: translateY(-4px);
  }

  .project-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background-color: #ffffff;
  }

  /* Tag row: testo mono, separatori dot 2x2 */
  .project-card__tags {
    display: flex;
    align-items: center;
    gap: 6px;
    margin: 24px 0 0 0;
    padding: 0;
    list-style: none;
    flex-wrap: wrap;
  }

  .project-card__tag {
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 14px;
    letter-spacing: 0.32px;
    line-height: 1;
    color: rgba(255, 255, 255, 0.8);
    white-space: nowrap;
  }

  .project-card__tag-sep {
    width: 2px;
    height: 2px;
    border-radius: 100%;
    background-color: rgba(255, 255, 255, 0.6);
    flex-shrink: 0;
  }

  .project-card__title {
    margin-top: 16px;
    font-family: var(--font-hero);
    font-weight: 400;
    font-size: 28px;
    letter-spacing: 0.32px;
    line-height: 1.2;
    color: #ffffff;
  }
</style>
