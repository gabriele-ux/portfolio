---
/*
 * Hero della homepage:
 * - h1 nome
 * - paragrafo descrittivo con bold + emoji inline
 * - meta rows: "Currently at" / "I worked with"
 */
import Container from "../case-study/Container.astro";

interface Props {
  name: string;
  currentlyAt: string;
  workedWith: string[];
}

const { name, currentlyAt, workedWith } = Astro.props;
---

<Container pyClass="pt-[var(--space-3xl)] pb-[var(--space-3xl)]">
  <div class="flex flex-col gap-[var(--space-lg)] items-start w-full">
    <h1 class="home-hero__title font-hero text-white leading-tight">
      {name}
    </h1>

    <p class="home-hero__lead text-white">
      <strong class="font-semibold">UX/Product Designer</strong> focused on Design
