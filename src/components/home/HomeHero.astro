            <linearGradient id="hh-grad-scalable" x1="10" y1="3.125" x2="10" y2="16.875" gradientUnits="userSpaceOnUse">
              <stop stop-color="#B1C76F" />
              <stop offset="1" stop-color="#82FE88" />
            </linearGradient>
          </defs>
