      .
    </p>

    <div class="home-hero__meta-group">
      <p class="home-hero__meta">
        <span class="text-[var(--color-text-body)]">Currently at:</span>
        <span class="text-white font-semibold">{currentlyAt}</span>
      </p>
      <p class="home-hero__meta">
        <span class="text-[var(--color-text-body)]">I worked with:</span>
        <span class="text-white font-semibold">{workedWith.join(", ")}</span>
      </p>
    </div>
  </div>
</Container>

<style>
  /* h1 — Bricolage Grotesque (font-hero), medium 500, 60px desktop con
   * scala fluida 36→60 tra 640 e 1440vw (stesso pattern di --text-hero). */
  .home-hero__title {
    font-size: clamp(36px, calc(16.8px + 3vw), 60px);
    font-weight: 500;
  }

  /* Lead text — scala fluida 16→20px tra 640 e 1440vw, stesso pattern
   * usato per --text-hero del case study. */
  .home-hero__lead {
    font-size: clamp(16px, calc(12.8px + 0.5vw), 20px);
    line-height: 1.55;
  }

  .home-hero__highlight {
    font-weight: 600;
  }

  /* Icone inline accanto al testo */
  .home-hero__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    vertical-align: -4px;
    /* +4px ai lati → con lo space char dell'HTML (~4px) = ~8px di gap totale */
    margin-inline: 4px;
  }

  /* Meta group — distanza dal lead = 36px esatti (parent flex gap
   * = var(--space-lg) + margin-top compensativo). */
  .home-hero__meta-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    margin-top: calc(36px - var(--space-lg));
  }

  /* Riga meta: label + value sulla stessa riga con 8px di gap.
   * flex-wrap permette il wrap pulito su mobile. */
  .home-hero__meta {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    column-gap: 8px;
    row-gap: 4px;
    font-size: clamp(16px, calc(12.8px + 0.5vw), 20px);
    line-height: 1.5;
  }
</style>
